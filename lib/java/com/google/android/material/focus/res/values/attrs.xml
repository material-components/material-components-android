<resources>

  <declare-styleable name="FocusRingDrawable">
    <!-- Whether focus rings are enabled. -->
    <attr name="focusRingsEnabled" format="boolean"/>
    <!-- The color of the outer focus ring. -->
    <attr name="focusRingsOuterStrokeColor" format="color"/>
    <!-- The color of the inner focus ring. -->
    <attr name="focusRingsInnerStrokeColor" format="color"/>
    <!-- The stroke width of the outer focus ring. -->
    <attr name="focusRingsOuterStrokeWidth" format="dimension"/>
    <!-- The stroke width of the inner focus ring. -->
    <attr name="focusRingsInnerStrokeWidth" format="dimension"/>
    <!-- The overall inset of the focus ring, applied to both the outer and
         inner strokes. -->
    <attr name="focusRingsInset" format="dimension"/>
    <!-- The additional inset of the inner focus ring. This inset value will
         stack on top of focusRingsInset. -->
    <attr name="focusRingsInnerStrokeInset" format="dimension"/>
    <!-- The radius of the focus ring. -->
    <attr name="focusRingsRadius" format="dimension"/>
    <!-- The shape appearance of the focus ring. -->
    <attr name="focusRingsShapeAppearance" format="reference"/>
  </declare-styleable>
</resources>
