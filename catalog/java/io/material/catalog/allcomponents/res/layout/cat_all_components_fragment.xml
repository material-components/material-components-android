<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/drawer_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <androidx.coordinatorlayout.widget.CoordinatorLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
      android:id="@+id/nested_scroll_view"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      app:layout_behavior="@string/appbar_scrolling_view_behavior">

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.search.SearchBar
          android:id="@+id/search_bar"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:hint="@string/cat_all_components_search_bar_hint">
        </com.google.android.material.search.SearchBar>

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:paddingHorizontal="16dp"
          android:orientation="vertical">

          <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.tabs.TabItem
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_tab_1"/>

            <com.google.android.material.tabs.TabItem
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_tab_2"/>

            <com.google.android.material.tabs.TabItem
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_tab_3"/>
          </com.google.android.material.tabs.TabLayout>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="8dp"/>

          <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_checkbox"/>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="4dp"/>

          <RadioButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_radio_button"/>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="4dp"/>

          <com.google.android.material.materialswitch.MaterialSwitch
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_switch"/>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="8dp"/>

          <com.google.android.material.button.MaterialButtonToggleGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <Button
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_toggle_group_connected"/>
            <Button
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_button"/>
            <Button
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_button_group"/>
          </com.google.android.material.button.MaterialButtonToggleGroup>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="4dp"/>

          <com.google.android.material.button.MaterialButtonGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <Button
              style="?attr/materialButtonTonalStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_button_group_standard"/>
            <Button
              style="?attr/materialButtonTonalStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_button"/>
            <Button
              style="?attr/materialButtonTonalStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_button_group"/>
          </com.google.android.material.button.MaterialButtonGroup>

          <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.chip.Chip
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_chip_1"/>

            <com.google.android.material.chip.Chip
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_chip_2"/>

            <com.google.android.material.chip.Chip
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_chip_3"/>
          </com.google.android.material.chip.ChipGroup>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="4dp"/>

          <com.google.android.material.button.MaterialSplitButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/cat_all_components_split_button"
              app:icon="@drawable/ic_edit_vd_theme_24dp"/>
            <Button
              android:id="@+id/split_button_expand"
              style="?attr/materialSplitButtonIconFilledStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              app:icon="@drawable/m3_split_button_chevron_avd"/>
          </com.google.android.material.button.MaterialSplitButton>

          <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
              style="?attr/floatingActionButtonStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_margin="8dp"
              android:layout_gravity="center"
              android:contentDescription="@string/cat_all_components_fab_content_desc"
              app:materialThemeOverlay="@style/ThemeOverlay.Material3Expressive.FloatingActionButton.Primary"
              app:srcCompat="@drawable/ic_add_24px"/>
            <com.google.android.material.floatingactionbutton.FloatingActionButton
              style="?attr/floatingActionButtonMediumStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_margin="8dp"
              android:layout_gravity="center"
              android:contentDescription="@string/cat_all_components_fab_content_desc"
              app:materialThemeOverlay="@style/ThemeOverlay.Material3Expressive.FloatingActionButton.Secondary"
              app:srcCompat="@drawable/ic_add_24px"/>
            <com.google.android.material.floatingactionbutton.FloatingActionButton
              style="?attr/floatingActionButtonLargeStyle"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_margin="8dp"
              android:layout_gravity="center"
              android:contentDescription="@string/cat_all_components_fab_content_desc"
              app:materialThemeOverlay="@style/ThemeOverlay.Material3Expressive.FloatingActionButton.Tertiary"
              app:srcCompat="@drawable/ic_add_24px" />
          </LinearLayout>

          <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            style="?attr/extendedFloatingActionButtonSmallStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="@string/cat_all_components_small_efab"
            app:materialThemeOverlay="@style/ThemeOverlay.Material3Expressive.FloatingActionButton.PrimaryContainer"
            app:icon="@drawable/ic_add_24px" />
          <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            style="?attr/extendedFloatingActionButtonMediumStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="@string/cat_all_components_medium_efab"
            app:materialThemeOverlay="@style/ThemeOverlay.Material3Expressive.FloatingActionButton.SecondaryContainer"
            app:icon="@drawable/ic_add_24px" />
          <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            style="?attr/extendedFloatingActionButtonLargeStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="@string/cat_all_components_large_efab"
            app:materialThemeOverlay="@style/ThemeOverlay.Material3Expressive.FloatingActionButton.TertiaryContainer"
            app:icon="@drawable/ic_add_24px" />

          <Space
            android:layout_width="wrap_content"
            android:layout_height="8dp"/>

          <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true">

            <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="32dp"
              android:layout_marginBottom="32dp"
              android:layout_gravity="center"
              android:text="@string/cat_all_components_card"/>
          </com.google.android.material.card.MaterialCardView>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>

          <com.google.android.material.textfield.TextInputLayout
            style="?attr/textInputFilledStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:hint="@string/cat_all_components_filled_text_field_hint"
              android:inputType="text"
              android:autofillHints="notApplicable" />
          </com.google.android.material.textfield.TextInputLayout>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>

          <com.google.android.material.textfield.TextInputLayout
            style="?attr/textInputOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:hint="@string/cat_all_components_outlined_text_field_hint"
              android:inputType="text"
              android:autofillHints="notApplicable" />
          </com.google.android.material.textfield.TextInputLayout>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>

          <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="3dp"
            app:menu="@menu/cat_all_components_menu"/>

          <com.google.android.material.slider.Slider
            android:id="@+id/slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"
            android:value="8.09"
            android:valueFrom="0.0"
            android:valueTo="11.0" />

          <com.google.android.material.slider.RangeSlider
            android:id="@+id/range_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"
            app:values="@array/cat_all_components_initial_slider_values"
            android:valueFrom="0.0"
            android:valueTo="11.0" />

          <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true" />

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>

          <com.google.android.material.progressindicator.LinearProgressIndicator
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true" />

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_dialogs_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

          <Button
            android:id="@+id/alert_dialog_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_alert_dialog_button"/>

          <Button
            style="?attr/materialButtonTonalStyle"
            android:id="@+id/date_picker_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_date_picker_button"/>

          <Button
            style="?attr/materialButtonOutlinedStyle"
            android:id="@+id/date_range_picker_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_date_range_picker_button"/>

          <Button
            style="?attr/borderlessButtonStyle"
            android:id="@+id/time_picker_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_time_picker_button"/>

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>

          <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_sheets_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall" />

          <Button
            style="?attr/materialButtonElevatedStyle"
            android:id="@+id/bottom_sheet_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_bottom_sheet_button" />

          <Button
            style="?attr/materialButtonTonalStyle"
            android:id="@+id/modal_side_sheet_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_all_components_side_sheet_button"
            app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.Small.Square" />

          <Space
            android:layout_width="wrap_content"
            android:layout_height="16dp"/>
        </LinearLayout>

        <androidx.coordinatorlayout.widget.CoordinatorLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content">

          <com.google.android.material.bottomappbar.BottomAppBar
            android:id="@+id/bottom_app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:menu="@menu/cat_all_components_menu"
            app:navigationIcon="@drawable/ic_drawer_menu_24px"/>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>
      </LinearLayout>
    </androidx.core.widget.NestedScrollView>
  </androidx.coordinatorlayout.widget.CoordinatorLayout>

  <com.google.android.material.navigation.NavigationView
    android:id="@+id/modal_nav_drawer"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    app:headerLayout="@layout/cat_all_components_nav_header"
    app:menu="@menu/cat_all_components_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
